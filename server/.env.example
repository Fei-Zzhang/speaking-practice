# 复制此文件为 .env 并填入真实值
# 使用 Supabase 云数据库（官网 https://supabase.com 国内一般可访问）

# Supabase 项目地址（在 Supabase 控制台 → Settings → API 里复制）
SUPABASE_URL=https://你的项目id.supabase.co

# Service Role Key（同上，用 service_role 密钥，不要暴露到前端）
SUPABASE_SERVICE_KEY=你的service_role密钥

# 服务端口
PORT=3003

# 前端页面地址（用于 CORS），部署时改成你的前端域名
CORS_ORIGIN=http://localhost:8080

# 教师账号首次注册口令（与学生端分离；勿泄露到前端仓库）
# 在 Supabase 执行 server/supabase-assignments.sql 后，登录教师端需填此口令完成注册
TEACHER_REGISTER_SECRET=请改成随机长字符串

# 学生端统一登录账号（与 standalone.html 中学生端一致；可改密码后同步改前端常量）
STUDENT_PORTAL_USERNAME=studentaccount
STUDENT_PORTAL_PASSWORD=45678

# Python 口语评测（教师端点「批改该题」时，Node 会转发音频到此地址）
PYTHON_BASE_URL=http://localhost:5001
